*{
	margin:0;
	padding:0;
	box-sizing: border-box;
	font-family:arial;
}
body{
	background: rgb(192, 192, 192);
	min-height: 100vh;
	display: flex;
	justify-content: center;
	align-items: center;
	padding: 40px;
}
.container{
	width:100%;
	max-width: 700px;
	background: lightblue;
	padding: 35px;
	border-radius: 15px;
	box-shadow: 0 10px 30px blue;
}
.welcome-box{
	background:lightblue;
	padding:40px;
	border-radius: 15px;
	text-align: center;
	width: 500px;
	box-shadow: 0 10px 30px black;
}
h1{
	color:blue;
	margin-bottom: 25px;
	text-align: center;
}
a{
	text-decoration: none;
	color:blue;
	background: lightgreen;
	padding: 10px 20px;
	border-radius:8px;
	display: inline-block;
	margin:10px;
	cursor: pointer;
	
}
a:hover{
	background: green;
}
form{
	margin-top:20px;
}
label{
	font-weight:600;
	display: block;
	margin-top: 15px;
	margin-bottom: 5px;
}
input[type=text],
input[type=password],
input[type=email],
input[type=number]{
	width:100%;
	padding: 12px;
	border:1px solid white;
	border-radius : 8px;
}
input[type=radio]{
	margin-left:10px;
	margin-right:5px;
}
input[type=submit]{
	width:100%;
	padding:13px;
	margin-top:25px;
	border:none;
	background: red;
	color: white;
	border-radius:8px;
	font-size:16px;
	cursor:pointer;
}
input[type=submit]:hover{
	background: orange;
}

table{
	width: 100%;
	border-collapse: collapse;
	background: white;
	box-shadow: 0 10px 25px rgba(0,0,0,.15);
	border-radius: 10px;
	overflow: hidden;
}
th{
	background: #2563eb;
	color: white;
	padding: 14px;
}
td{
	padding: 12px;
	text-align: center;
	border-bottom: 1px solid #ddd;
}
tr:nth-child(even){
	background:lightblue;
}

