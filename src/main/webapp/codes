<%@page import="com.ty.emp_management.entity.Employee"%>
<%@page import="com.ty.emp_management.dao.EmployeeDao"%>
<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
<link rel="stylesheet" href="style.css">
</head>
<body>
	<%
		int empid = Integer.parseInt(request.getParameter("id"));
		EmployeeDao dao = new EmployeeDao();
		Employee emp = dao.fetchById(empid);
	%>
	<div class="container">
	<form action="updateEmployee">
		<label>Empid: </label><input type="text" name="empid" value="<%=emp.getEmpid() %>" readonly><br>
		<label>Name: </label><input type="text" name="name" value="<%=emp.getName() %>"><br>
		<label>Email: </label><input type="email" name="email" value="<%=emp.getEmail() %>"><br>
		<label>Password: </label><input type="password" name="password" value="<%=emp.getPassword() %>"><br>
		<label>Age: </label><input type="number" name="age" value="<%=emp.getAge() %>"><br>
		<label>Gender: Male<input type="radio" name="gender" value="male">
		Female<input type="radio" name="gender" value="female"><br>
		<label>Salary: </label><input type="text" name="salary" value="<%=emp.getSalary() %>"><br>
		<label>Department: </label><input type="text" name="department" value="<%=emp.getDepartment() %>"><br>
		<input type="submit" value="update">
		</div>
	</form>
</body>
</html>